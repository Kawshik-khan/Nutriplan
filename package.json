{
  "name": "nutriplan-monolithic",
  "version": "0.1.0",
  "private": true,
  "description": "Monolithic Nutriplan application with frontend and backend",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "npm --prefix frontend run preview",
    "start:backend": "npm --prefix backend run start",
    "install:all": "npm install && npm --prefix frontend install && npm --prefix backend install",
    "test": "npm --prefix frontend run test",
    "lint": "npm --prefix frontend run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "frontend",
    "backend"
  ]
}
