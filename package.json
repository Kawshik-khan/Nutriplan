{
  "name": "nutriplan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix Nutriplan-main run dev",
    "dev:landing": "npm --prefix Nutriplanlandingpage-main run dev",
    "dev:dashboard": "npm --prefix Nutriplan-main run dev",
    "dev:all": "powershell -ExecutionPolicy Bypass -File start-all.ps1",
    "build": "next build",
    "build:frontend": "npm --prefix Nutriplan-main run build",
    "build:landing": "npm --prefix Nutriplanlandingpage-main run build",
    "build:dashboard": "npm --prefix Nutriplan-main run build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
